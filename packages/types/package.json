{
  "name": "@netlium/types",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Netlium Systems shared domain model package for institutional capital operating systems.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "check-types": "pnpm exec tsc -p tsconfig.json --noEmit",
    "lint": "pnpm exec eslint -c ../config/eslint.config.mjs \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "format": "pnpm exec prettier --write \"src/**/*.{ts,tsx}\" \"README.md\""
  }
}
