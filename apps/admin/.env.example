# =============================================================================
# Neptlium Admin Console — apps/admin environment variables
#
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must NEVER be committed.
#
# Production values are set in the Vercel project dashboard (admin.neptlium.com).
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE — public keys (same project as apps/app)
# Found in: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# SUPABASE — service role key (server-only, bypasses RLS)
# WARNING: Never expose this to the browser.
# Found in: Supabase Dashboard → Project Settings → API → service_role
# -----------------------------------------------------------------------------

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here


# -----------------------------------------------------------------------------
# APPLICATION ORIGIN
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=http://localhost:3002
