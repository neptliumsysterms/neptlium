# =============================================================================
# Neptlium — apps/app environment variables
#
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must NEVER be committed.
#
# Production values are set in the Vercel project dashboard, not here.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE — public keys (safe to expose to the browser)
#
# Found in: Supabase Dashboard → Project Settings → API → Project API keys
# -----------------------------------------------------------------------------

# Your Supabase project REST and Auth endpoint
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (new Supabase format — replaces the old anon JWT)
# Copy the value labelled "publishable" in the API keys section
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# SUPABASE — private key (server only)
#
# !! NEVER expose this in the browser or import it from a Client Component !!
# !! Set to "Production" environment only in Vercel — not Preview or Dev   !!
#
# Found in: Supabase Dashboard → Project Settings → API → service_role key
# -----------------------------------------------------------------------------

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# -----------------------------------------------------------------------------
# APPLICATION ORIGIN
#
# Used to build absolute URLs in server actions (e.g. Supabase emailRedirectTo).
# Must match the domain your users actually visit.
#
# Local dev:       http://localhost:3001
# Vercel preview:  https://neptlium-git-your-branch.vercel.app
# Production:      https://app.neptlium.com
#
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL:      https://app.neptlium.com
#   Redirect URLs: https://app.neptlium.com/auth/confirm
#                  https://app.neptlium.com/update-password
#                  http://localhost:3001/auth/confirm
#                  http://localhost:3001/update-password
#                  https://*.vercel.app/auth/confirm
#                  https://*.vercel.app/update-password
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=http://localhost:3001


# -----------------------------------------------------------------------------
# RESEND — transactional email (server only)
#
# Used by Supabase SMTP to deliver OTP verification and password reset emails.
# Configure in: Supabase Dashboard → Authentication → SMTP Settings
#   Host:     smtp.resend.com
#   Port:     465
#   Username: resend
#   Password: <your Resend API key>
#   Sender:   Neptlium <verify@auth.neptlium.com>
#
# Found in: resend.com → API Keys
# !! NEVER expose this key in the browser !!
# -----------------------------------------------------------------------------

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# NODE ENVIRONMENT (optional — set automatically by Next.js in most contexts)
# -----------------------------------------------------------------------------

NODE_ENV=development
