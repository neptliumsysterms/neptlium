# =========================================================
# NETLIUM SYSTEMS
# Production .gitignore
# Next.js 15 + Turborepo + pnpm + Supabase + Vercel
# =========================================================

# ---------------------------------------------------------
# Dependencies
# ---------------------------------------------------------
node_modules/
.pnpm-store/

# Yarn
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ---------------------------------------------------------
# Build Output
# ---------------------------------------------------------
dist/
build/
out/
coverage/
.nyc_output/

# ---------------------------------------------------------
# Next.js
# ---------------------------------------------------------
.next/
**/.next/

# ---------------------------------------------------------
# Turborepo
# ---------------------------------------------------------
.turbo/

# ---------------------------------------------------------
# Vercel
# ---------------------------------------------------------
.vercel/

# ---------------------------------------------------------
# TypeScript
# ---------------------------------------------------------
*.tsbuildinfo

# ---------------------------------------------------------
# Environment Variables
# ---------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ---------------------------------------------------------
# Diagnostic Reports
# ---------------------------------------------------------
report.*.json

# ---------------------------------------------------------
# Runtime
# ---------------------------------------------------------
pids/
*.pid
*.pid.lock
*.seed

# ---------------------------------------------------------
# Cache
# ---------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.vite/
.svelte-kit/
.nuxt/
.output/
.docusaurus/
.fusebox/

# ---------------------------------------------------------
# Testing
# ---------------------------------------------------------
.vitest/
playwright-report/
test-results/

# ---------------------------------------------------------
# Firebase
# ---------------------------------------------------------
.firebase/

# ---------------------------------------------------------
# Serverless
# ---------------------------------------------------------
.serverless/

# ---------------------------------------------------------
# Local Databases
# ---------------------------------------------------------
.dynamodb/

# ---------------------------------------------------------
# VS Code
# ---------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# ---------------------------------------------------------
# JetBrains
# ---------------------------------------------------------
.idea/

# ---------------------------------------------------------
# macOS
# ---------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ---------------------------------------------------------
# Windows
# ---------------------------------------------------------
Thumbs.db
Desktop.ini

# ---------------------------------------------------------
# Linux
# ---------------------------------------------------------
*~

# ---------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo

# ---------------------------------------------------------
# Package Archives
# ---------------------------------------------------------
*.tgz

# ---------------------------------------------------------
# Misc
# ---------------------------------------------------------
.node_repl_history
.tern-port
.lock-wscript

# ---------------------------------------------------------
# Supabase Local Development
# (Keep the folder structure, ignore generated files)
# ---------------------------------------------------------
supabase/.temp/
supabase/.branches/
supabase/.cache/

# ---------------------------------------------------------
# Generated Documentation
# ---------------------------------------------------------
*.pdf
*.zip

# ---------------------------------------------------------
# Never Ignore
# ---------------------------------------------------------
!.gitkeep
!.github/
!README.md
!LICENSE