{
  "name": "netliumsystems",
  "version": "1.0.0",
  "private": true,
  "description": "Netlium Systems monorepo",
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"No test suite configured yet\""
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.3.1",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  }
}